{
  "Jwt": {
    "Issuer": "ehr-platform",
    "Audience": "ehr-platform-clients"
  },
  "ReverseProxy": {
    "Routes": {
      "tenant": {
        "ClusterId": "tenant",
        "Match": { "Path": "/tenant/{**catch-all}" },
        "Transforms": [{ "PathRemovePrefix": "/tenant" }]
      },
      "identity": {
        "ClusterId": "identity",
        "Match": { "Path": "/identity/{**catch-all}" },
        "Transforms": [{ "PathRemovePrefix": "/identity" }]
      },
      "patient": {
        "ClusterId": "patient",
        "Match": { "Path": "/patient/{**catch-all}" },
        "Transforms": [{ "PathRemovePrefix": "/patient" }]
      },
      "appointment": {
        "ClusterId": "appointment",
        "Match": { "Path": "/appointment/{**catch-all}" },
        "Transforms": [{ "PathRemovePrefix": "/appointment" }]
      },
      "encounter": {
        "ClusterId": "encounter",
        "Match": { "Path": "/encounter/{**catch-all}" },
        "Transforms": [{ "PathRemovePrefix": "/encounter" }]
      },
      "audit": {
        "ClusterId": "audit",
        "Match": { "Path": "/audit/{**catch-all}" },
        "Transforms": [{ "PathRemovePrefix": "/audit" }]
      },
      "kafka-ui": {
        "ClusterId": "kafka-ui",
        "Match": { "Path": "/kafka-ui/{**catch-all}" },
        "Transforms": [{ "PathRemovePrefix": "/kafka-ui" }]
      },
      "pgadmin": {
        "ClusterId": "pgadmin",
        "Match": { "Path": "/pgadmin/{**catch-all}" },
        "Transforms": [{ "PathRemovePrefix": "/pgadmin" }]
      }
    },
    "Clusters": {
      "tenant": { "Destinations": { "default": { "Address": "http://localhost:5191/" } } },
      "identity": { "Destinations": { "default": { "Address": "http://localhost:5192/" } } },
      "patient": { "Destinations": { "default": { "Address": "http://localhost:5193/" } } },
      "appointment": { "Destinations": { "default": { "Address": "http://localhost:5194/" } } },
      "encounter": { "Destinations": { "default": { "Address": "http://localhost:5195/" } } },
      "audit": { "Destinations": { "default": { "Address": "http://localhost:5196/" } } },
      "kafka-ui": { "Destinations": { "default": { "Address": "http://kafka-ui:8080/" } } },
      "pgadmin": { "Destinations": { "default": { "Address": "http://pgadmin:80/" } } }
    }
  },
  "AllowedHosts": "*"
}
